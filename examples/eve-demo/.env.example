# Upstash Redis — required. Create a database at https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# OpenAI — required. The agent model is gpt-5.4-mini.
OPENAI_API_KEY=

# Upstash Box — optional. Only needed if you use the sandbox (agent/sandbox).
UPSTASH_BOX_API_KEY=
