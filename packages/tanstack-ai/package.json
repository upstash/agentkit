{
  "name": "@upstash/agentkit-tanstack-ai",
  "version": "0.1.0",
  "description": "TanStack AI adapter for Upstash AgentKit: persistent chat history, semantic-cached generation, cached tools, and memory injection.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "upstash",
    "tanstack",
    "tanstack-ai",
    "ai",
    "agent",
    "memory",
    "rag",
    "llm",
    "cache",
    "tools"
  ],
  "dependencies": {
    "@upstash/agentkit-sdk": "workspace:*"
  },
  "devDependencies": {
    "@upstash/redis": "^1.38.0",
    "dotenv": "^16.4.5"
  },
  "peerDependencies": {
    "@tanstack/ai": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/ai": {
      "optional": true
    }
  }
}
