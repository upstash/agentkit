{
  "name": "@upstash/agentkit-ai-sdk",
  "version": "0.1.0",
  "description": "Vercel AI SDK adapter for Upstash AgentKit: persistent chat history, semantic-cached generation, cached tools, memory injection, and telemetry.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "upstash",
    "ai-sdk",
    "vercel",
    "ai",
    "agent",
    "memory",
    "rag",
    "llm",
    "cache",
    "tools"
  ],
  "dependencies": {
    "@upstash/agentkit-sdk": "workspace:*",
    "@upstash/redis": "^1.38.0",
    "zod": "^3.23.8 || ^4",
    "@upstash/ratelimit": "^2.0.5"
  },
  "devDependencies": {
    "@upstash/redis": "^1.38.0",
    "dotenv": "^16.4.5",
    "ai": "^5",
    "@ai-sdk/provider": "^2",
    "@ai-sdk/openai": "^2"
  },
  "peerDependencies": {
    "ai": ">=5"
  },
  "peerDependenciesMeta": {}
}
