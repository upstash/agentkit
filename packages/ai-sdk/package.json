{
  "name": "@upstash/agentkit-ai-sdk",
  "version": "0.2.0",
  "description": "Upstash AgentKit adapter for the Vercel AI SDK: chat history, memory tools, Redis-Search tools, rate limiting, and cached tools.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/upstash/agentkit.git",
    "directory": "packages/ai-sdk"
  },
  "homepage": "https://upstash.com/docs/redis/sdks/agentkit/ai-sdk",
  "bugs": {
    "url": "https://github.com/upstash/agentkit/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "upstash",
    "ai-sdk",
    "vercel",
    "ai",
    "agent",
    "memory",
    "rag",
    "llm",
    "cache",
    "tools"
  ],
  "dependencies": {
    "@upstash/agentkit-sdk": "workspace:*",
    "@upstash/redis": "^1.38.0",
    "zod": "^3.23.8 || ^4"
  },
  "devDependencies": {
    "@upstash/redis": "^1.38.0",
    "dotenv": "^16.4.5",
    "ai": "7.0.0-beta.178",
    "@ai-sdk/provider": "^4.0.0-beta",
    "@ai-sdk/openai": "^4.0.0-beta"
  },
  "peerDependencies": {
    "ai": ">=7.0.0-beta"
  },
  "peerDependenciesMeta": {}
}
