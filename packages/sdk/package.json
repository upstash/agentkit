{
  "name": "@upstash/agentkit-sdk",
  "version": "0.1.0",
  "description": "Core primitives for building AI agents on Upstash Redis: memory, chat history, semantic & tool caching, telemetry, sandbox, and RAG.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "upstash",
    "redis",
    "vector",
    "ai",
    "agent",
    "memory",
    "rag",
    "llm",
    "cache"
  ],
  "dependencies": {
    "@upstash/ratelimit": "^2.0.5"
  },
  "peerDependencies": {
    "@upstash/redis": ">=1.38.0"
  },
  "devDependencies": {
    "@upstash/redis": "^1.38.0",
    "dotenv": "^16.4.5"
  }
}
